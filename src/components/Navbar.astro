---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import SearchModal from './SearchModal.astro';
import logoImg from '../assets/images/logo.png';

interface Props {
  alternateUrl?: string;
}

const { alternateUrl } = Astro.props;

const currentLocale = Astro.currentLocale || 'en';
const localePrefix = currentLocale === 'en' ? '' : `/${currentLocale}`;

// Links
const homeLink = `${localePrefix}/`;
const categoriesLink = `${localePrefix}/categories`;
const aboutLink = `${localePrefix}/about`;
const savedLink = `${localePrefix}/saved`;

// Active state checks
const pathname = Astro.url.pathname;
const isHome = pathname === homeLink || pathname === `${homeLink}index.html`;
const isCategories = pathname === categoriesLink || pathname.startsWith(`${localePrefix}/category/`);
const isAbout = pathname === aboutLink;
const isSaved = pathname === savedLink;

const translations = {
  en: {
    home: "Home",
    series: "Series",
    about: "About",
    saved: "Saved Items",
    search: "Search"
  },
  fr: {
    home: "Accueil",
    series: "Séries",
    about: "À Propos",
    saved: "Éléments enregistrés",
    search: "Rechercher"
  }
};
const t = translations[currentLocale as 'en' | 'fr'] || translations.en;
---

<nav 
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-500 border-b h-24 bg-cream-50/80 dark:bg-coffee-900/80 backdrop-blur-xl border-cream-200 dark:border-coffee-800"
>
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
    <a href={homeLink} class="flex items-center gap-3 group">
      <div id="nav-logo-container" class="rounded-xl overflow-hidden shadow-sm border border-cream-200 group-hover:scale-105 transition-all duration-500 w-11 h-11 flex items-center justify-center">
        <Image src={logoImg} class="w-full h-full object-cover" alt="Logo" />
      </div>
      <div class="flex flex-row items-center gap-1">
        <span id="nav-brand-text" class="hidden sm:inline font-black text-stone-800 dark:text-stone-100 transition-all duration-500 text-xl">Bab Al-Ridha</span>
        <div class="hidden sm:inline items-center">
          <span class="logo-block bg-[#EC4899] rotate-[-6deg] transition-all" id="logo-k">K</span>
          <span class="logo-block bg-[#10B981] rotate-[8deg] transition-all" id="logo-i">I</span>
          <span class="logo-block bg-[#FBBF24] rotate-[-4deg] transition-all" id="logo-d">D</span>
          <span class="logo-block bg-[#F472B6] rotate-[5deg] transition-all" id="logo-s">S</span>
        </div>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-10 font-bold text-stone-500 dark:text-stone-400">
      <a 
        href={homeLink} 
        class={isHome 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >{t.home}</a>
      <a 
        href={categoriesLink} 
        class={isCategories 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >{t.series}</a>
      <a 
        href={aboutLink} 
        class={isAbout 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >{t.about}</a>
    </div>

    <div class="flex items-center gap-2">
      <button 
        id="search-btn"
        class="flex items-center justify-center w-10 h-10 bg-cream-100/50 dark:bg-coffee-800/50 rounded-full text-stone-500 hover:text-stone-800 dark:hover:text-white transition-all border border-cream-200 dark:border-coffee-800"
        aria-label={t.search}
      >
        <Icon name="Search" size={18} />
      </button>
      <a 
        href={savedLink}
        class="flex items-center justify-center w-10 h-10 bg-cream-100/50 dark:bg-coffee-800/50 rounded-full text-stone-500 hover:text-pink-500 transition-all border border-cream-200 dark:border-coffee-800"
        aria-label={t.saved}
      >
        <Icon name="Heart" size={18} fill={isSaved ? "currentColor" : "none"} class={isSaved ? "text-pink-500" : ""} />
      </a>

      <button 
        id="theme-btn" 
        class="w-10 h-10 flex items-center justify-center bg-cream-100/50 dark:bg-coffee-800/50 rounded-full text-stone-500 hover:text-stone-800 dark:hover:text-white transition-all border border-cream-200 dark:border-coffee-800 animate-in fade-in"
        aria-label="Toggle Theme"
      >
        <span class="dark:hidden"><Icon name="Moon" size={18} /></span>
        <span class="hidden dark:block"><Icon name="Sun" size={18} /></span>
      </button>

      <!-- Language Switcher desktop -->
      <div class="hidden sm:flex items-center gap-1 bg-cream-100/50 dark:bg-coffee-800/50 rounded-full p-1 border border-cream-200 dark:border-coffee-800 text-[10px] font-black uppercase ml-2">
        <a 
          href={currentLocale === 'en' ? '#' : alternateUrl || '/'}
          class={`px-2.5 py-1.5 rounded-full transition-all ${currentLocale === 'en' ? 'bg-accent-light dark:bg-accent-dark text-stone-900 shadow-md pointer-events-none' : 'text-stone-500 hover:text-stone-800 dark:hover:text-white'}`}
          data-lang-btn="en"
        >
          EN
        </a>
        <a 
          href={currentLocale === 'fr' ? '#' : alternateUrl || '/fr'}
          class={`px-2.5 py-1.5 rounded-full transition-all ${currentLocale === 'fr' ? 'bg-accent-light dark:bg-accent-dark text-stone-900 shadow-md pointer-events-none' : 'text-stone-500 hover:text-stone-800 dark:hover:text-white'}`}
          data-lang-btn="fr"
        >
          FR
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-500 ml-2" aria-label="Toggle Menu">
        <span id="menu-icon-open"><Icon name="Menu" size={24} /></span>
        <span id="menu-icon-close" class="hidden"><Icon name="X" size={24} /></span>
      </button>
    </div>
  </div>
  
  <!-- Animated Mobile Menu -->
  <div 
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-in-out bg-cream-50 dark:bg-coffee-900 border-t border-cream-200 dark:border-coffee-800 max-h-0 opacity-0"
  >
    <div class="flex flex-col gap-6 p-8">
      <a href={homeLink} class="text-2xl font-black text-stone-800 dark:text-stone-100">{t.home}</a>
      <a href={categoriesLink} class="text-2xl font-black text-stone-800 dark:text-stone-100">{t.series}</a>
      <a href={aboutLink} class="text-2xl font-black text-stone-800 dark:text-stone-100">{t.about}</a>
      
      <!-- Mobile Language Switcher -->
      <div class="flex items-center justify-center gap-4 border-t border-cream-200 dark:border-coffee-800 pt-6">
        <a 
          href={currentLocale === 'en' ? '#' : alternateUrl || '/'}
          class={`px-4 py-2 rounded-full font-bold text-sm ${currentLocale === 'en' ? 'bg-accent-light dark:bg-accent-dark text-stone-900 shadow-md pointer-events-none' : 'text-stone-500 dark:text-stone-400'}`}
          data-lang-btn="en"
        >
          English
        </a>
        <a 
          href={currentLocale === 'fr' ? '#' : alternateUrl || '/fr'}
          class={`px-4 py-2 rounded-full font-bold text-sm ${currentLocale === 'fr' ? 'bg-accent-light dark:bg-accent-dark text-stone-900 shadow-md pointer-events-none' : 'text-stone-500 dark:text-stone-400'}`}
          data-lang-btn="fr"
        >
          Français
        </a>
      </div>
    </div>
  </div>
</nav>

<SearchModal />

<script>
  const setupNavbar = () => {
    const nav = document.getElementById('main-nav');
    
    // Scroll handler
    const handleScroll = () => {
      nav?.classList.toggle('scrolled', window.scrollY > 20);
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Run once in case already scrolled

    // Mobile Menu Toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    mobileMenuBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('max-h-[350px]');
      if (isOpen) {
        mobileMenu?.classList.remove('max-h-[350px]', 'opacity-100');
        mobileMenu?.classList.add('max-h-0', 'opacity-0');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      } else {
        mobileMenu?.classList.remove('max-h-0', 'opacity-0');
        mobileMenu?.classList.add('max-h-[350px]', 'opacity-100');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
    });

    // Language click handler to save preference in localStorage
    document.querySelectorAll('[data-lang-btn]').forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = btn.getAttribute('data-lang-btn');
        if (lang) {
          localStorage.setItem('language', lang);
        }
      });
    });

    // Theme Toggle
    const themeBtn = document.getElementById('theme-btn');
    themeBtn?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('app-theme', 'light');
      } else {
        document.documentElement.classList.add('dark');
        localStorage.setItem('app-theme', 'dark');
      }
      window.dispatchEvent(new CustomEvent('theme-changed'));
    });

    // Search Trigger
    const searchBtn = document.getElementById('search-btn');
    searchBtn?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-search'));
    });
  };

  // Run on page load
  document.addEventListener('astro:page-load', setupNavbar);
</script>
