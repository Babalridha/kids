---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import SearchModal from './SearchModal.astro';
import logoImg from '../assets/images/logo.png';

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isCategories = pathname === '/categories' || pathname.startsWith('/category/');
const isAbout = pathname === '/about';
const isSaved = pathname === '/saved';
---

<nav 
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-[100] transition-all duration-500 border-b h-24 bg-cream-50/80 dark:bg-coffee-900/80 backdrop-blur-xl border-cream-200 dark:border-coffee-800"
>
  <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div id="nav-logo-container" class="rounded-xl overflow-hidden shadow-sm border border-cream-200 group-hover:scale-105 transition-all duration-500 w-11 h-11 flex items-center justify-center">
        <Image src={logoImg} class="w-full h-full object-cover" alt="Logo" />
      </div>
      <div class="flex flex-row items-center gap-1">
        <span id="nav-brand-text" class="hidden sm:inline font-black text-stone-800 dark:text-stone-100 transition-all duration-500 text-xl">Bab Al-Ridha</span>
        <div class="hidden sm:inline items-center">
          <span class="logo-block bg-[#EC4899] rotate-[-6deg] transition-all" id="logo-k">K</span>
          <span class="logo-block bg-[#10B981] rotate-[8deg] transition-all" id="logo-i">I</span>
          <span class="logo-block bg-[#FBBF24] rotate-[-4deg] transition-all" id="logo-d">D</span>
          <span class="logo-block bg-[#F472B6] rotate-[5deg] transition-all" id="logo-s">S</span>
        </div>
      </div>
    </a>

    <div class="hidden md:flex items-center gap-10 font-bold text-stone-500 dark:text-stone-400">
      <a 
        href="/" 
        class={isHome 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >Home</a>
      <a 
        href="/categories" 
        class={isCategories 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >Series</a>
      <a 
        href="/about" 
        class={isAbout 
          ? 'text-stone-800 dark:text-white underline decoration-accent-light dark:decoration-accent-dark decoration-4 underline-offset-8' 
          : 'hover:text-stone-800 dark:hover:text-white transition-colors'}
      >About</a>
    </div>

    <div class="flex items-center gap-2">
      <button 
        id="search-btn"
        class="flex items-center justify-center w-10 h-10 bg-cream-100/50 dark:bg-coffee-800/50 rounded-full text-stone-500 hover:text-stone-800 dark:hover:text-white transition-all border border-cream-200 dark:border-coffee-800"
        aria-label="Search"
      >
        <Icon name="Search" size={18} />
      </button>
      <a 
        href="/saved"
        class="flex items-center justify-center w-10 h-10 bg-cream-100/50 dark:bg-coffee-800/50 rounded-full text-stone-500 hover:text-pink-500 transition-all border border-cream-200 dark:border-coffee-800"
        aria-label="Saved Items"
      >
        <Icon name="Heart" size={18} fill={isSaved ? "currentColor" : "none"} class={isSaved ? "text-pink-500" : ""} />
      </a>

      <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-500 ml-2" aria-label="Toggle Menu">
        <span id="menu-icon-open"><Icon name="Menu" size={24} /></span>
        <span id="menu-icon-close" class="hidden"><Icon name="X" size={24} /></span>
      </button>
    </div>
  </div>
  
  <!-- Animated Mobile Menu -->
  <div 
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-in-out bg-cream-50 dark:bg-coffee-900 border-t border-cream-200 dark:border-coffee-800 max-h-0 opacity-0"
  >
    <div class="flex flex-col gap-6 p-8">
      <a href="/" class="text-2xl font-black text-stone-800 dark:text-stone-100">Home</a>
      <a href="/categories" class="text-2xl font-black text-stone-800 dark:text-stone-100">Series</a>
      <a href="/about" class="text-2xl font-black text-stone-800 dark:text-stone-100">About</a>
    </div>
  </div>
</nav>

<SearchModal />

<script>
  const setupNavbar = () => {
    const nav = document.getElementById('main-nav');
    const logoContainer = document.getElementById('nav-logo-container');
    const brandText = document.getElementById('nav-brand-text');
    
    // Logo blocks
    const logoK = document.getElementById('logo-k');
    const logoI = document.getElementById('logo-i');
    const logoD = document.getElementById('logo-d');
    const logoS = document.getElementById('logo-s');

    // Scroll handler
    const handleScroll = () => {
      nav?.classList.toggle('scrolled', window.scrollY > 20);
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Run once in case already scrolled

    // Mobile Menu Toggle
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    mobileMenuBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.contains('max-h-[300px]');
      if (isOpen) {
        mobileMenu?.classList.remove('max-h-[300px]', 'opacity-100');
        mobileMenu?.classList.add('max-h-0', 'opacity-0');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      } else {
        mobileMenu?.classList.remove('max-h-0', 'opacity-0');
        mobileMenu?.classList.add('max-h-[300px]', 'opacity-100');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
    });



    // Search Trigger
    const searchBtn = document.getElementById('search-btn');
    searchBtn?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-search'));
    });
  };

  // Run on page load
  document.addEventListener('astro:page-load', setupNavbar);
</script>
