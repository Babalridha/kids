---
import Icon from './Icon.astro';
---

<div id="global-player-root" class="transition-all" transition:persist>
  <!-- Expanded Video Overlay -->
  <div id="player-expanded-overlay" class="fixed inset-0 z-[250] bg-black flex flex-col items-center justify-center p-4 hidden animate-in fade-in duration-500">
    <button 
      id="player-minimize-btn"
      class="absolute top-8 right-8 w-14 h-14 bg-white/10 hover:bg-white/20 backdrop-blur rounded-full flex items-center justify-center text-white transition-all z-10"
    >
      <Icon name="Minimize2" size={24} />
    </button>
    
    <div class="w-full max-w-5xl aspect-video rounded-3xl overflow-hidden shadow-2xl bg-stone-900 border-4 border-stone-800">
      <iframe
        id="player-youtube-iframe"
        width="100%"
        height="100%"
        src=""
        title="Youtube Player"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
    
    <div class="mt-10 text-center space-y-4">
      <h2 id="player-expanded-title" class="text-3xl md:text-5xl font-black text-white"></h2>
      <p id="player-expanded-category" class="text-xl text-stone-400 font-medium"></p>
      <button 
        id="player-goto-details-btn"
        class="mt-4 flex items-center gap-2 px-8 py-4 rounded-full font-black hover:scale-105 transition-transform text-stone-900"
      >
        Go to Details <Icon name="ExternalLink" size={20} />
      </button>
    </div>
  </div>

  <!-- Floating Capsule Player -->
  <div id="player-capsule-container" class="fixed bottom-8 left-0 right-0 z-[200] px-4 pointer-events-none hidden">
    <div class="max-w-4xl mx-auto bg-white/95 dark:bg-stone-900/95 backdrop-blur-2xl rounded-full shadow-[0_30px_60px_-15px_rgba(0,0,0,0.3)] border border-cream-200 dark:border-coffee-800 p-3 flex items-center gap-4 md:gap-8 pointer-events-auto group relative animate-in slide-in-from-bottom duration-500">
      
      <!-- Progress bar with dynamic color -->
      <div id="player-progress-bar-container" class="absolute top-0 left-12 right-12 h-1 group-hover:h-2 transition-all cursor-pointer">
         <div class="w-full h-full bg-stone-100 dark:bg-stone-800 rounded-full overflow-hidden">
            <div 
              id="player-progress-bar"
              class="h-full transition-all duration-300" 
              style="width: 15%; background-color: #eddcc5;" 
            />
         </div>
      </div>

      <!-- Thumbnail and Info -->
      <div class="flex items-center gap-3 md:w-1/4">
        <div id="player-thumbnail-trigger" class="relative cursor-pointer group/thumb">
          <img 
            id="player-thumbnail-img"
            src="" 
            class="w-12 h-12 rounded-xl object-cover shadow-sm border-2 border-cream-50 dark:border-coffee-800" 
            alt="Playing" 
          />
          <div class="absolute inset-0 bg-black/40 rounded-xl opacity-0 group-hover/thumb:opacity-100 flex items-center justify-center transition-opacity">
            <Icon name="ExternalLink" size={14} class="text-white" />
          </div>
        </div>
        <div class="min-w-0">
          <h4 id="player-title" class="text-sm font-black text-stone-800 dark:text-stone-100 truncate"></h4>
          <p id="player-category" class="text-[10px] font-bold text-stone-400 dark:text-stone-500 uppercase tracking-wider"></p>
        </div>
      </div>

      <!-- Controls -->
      <div class="flex-1 flex items-center justify-center gap-4 md:gap-8">
        <button class="text-stone-600 dark:text-stone-300 hover:text-stone-800 dark:hover:text-stone-100 transition-colors">
          <Icon name="SkipBack" fill="currentColor" size={24} />
        </button>
        <button 
          id="player-play-toggle-btn"
          class="w-14 h-14 text-stone-900 rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all"
          style="background-color: #eddcc5;"
        >
          <!-- Show pause when playing, play when paused -->
          <span id="player-btn-pause"><Icon name="Pause" fill="currentColor" size={28} /></span>
          <span id="player-btn-play" class="hidden"><Icon name="Play" fill="currentColor" size={28} class="ml-1" /></span>
        </button>
        <button class="text-stone-600 dark:text-stone-300 hover:text-stone-800 dark:hover:text-stone-100 transition-colors">
          <Icon name="SkipForward" fill="currentColor" size={24} />
        </button>
      </div>

      <!-- Secondary Controls -->
      <div class="hidden md:flex items-center justify-end gap-5 md:w-1/4 pr-4">
        <button 
          id="player-expand-btn"
          class="p-2 bg-cream-50 dark:bg-coffee-800 text-stone-400 hover:text-stone-800 dark:hover:text-stone-100 rounded-xl transition-all"
        >
          <Icon name="Maximize2" size={20} />
        </button>
        <div class="flex items-center gap-3">
          <Icon name="Volume2" size={20} class="text-stone-400" />
          <div class="w-20 h-1.5 bg-stone-100 dark:bg-stone-800 rounded-full overflow-hidden">
             <div id="player-volume-bar" class="h-full w-3/4 transition-all" style="background-color: #eddcc5;" />
          </div>
        </div>
        <button 
          id="player-close-btn"
          class="p-2 text-stone-400 hover:text-red-500 transition-colors"
        >
          <Icon name="X" size={20} />
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { getDominantColor } from '../utils/colorExtractor';

  const getImgSrc = (img: any) => typeof img === 'string' ? img : (img?.src || '');

  let currentAudio = null;
  let isPlaying = false;
  let isExpanded = false;
  let dominantColor = '#eddcc5';

  const root = document.getElementById('global-player-root');
  const capsule = document.getElementById('player-capsule-container');
  const expandedOverlay = document.getElementById('player-expanded-overlay');
  const iframe = document.getElementById('player-youtube-iframe') as HTMLIFrameElement;
  
  const thumbnailImg = document.getElementById('player-thumbnail-img') as HTMLImageElement;
  const titleEl = document.getElementById('player-title');
  const categoryEl = document.getElementById('player-category');
  
  const expandedTitleEl = document.getElementById('player-expanded-title');
  const expandedCategoryEl = document.getElementById('player-expanded-category');
  
  const playToggleBtn = document.getElementById('player-play-toggle-btn');
  const btnPause = document.getElementById('player-btn-pause');
  const btnPlay = document.getElementById('player-btn-play');
  
  const progressBar = document.getElementById('player-progress-bar');
  const volumeBar = document.getElementById('player-volume-bar');
  
  const expandBtn = document.getElementById('player-expand-btn');
  const minimizeBtn = document.getElementById('player-minimize-btn');
  const closeBtn = document.getElementById('player-close-btn');
  const gotoDetailsBtn = document.getElementById('player-goto-details-btn');
  const thumbnailTrigger = document.getElementById('player-thumbnail-trigger');

  const updateUI = () => {
    if (!currentAudio) {
      capsule?.classList.add('hidden');
      expandedOverlay?.classList.add('hidden');
      if (iframe) iframe.src = '';
      return;
    }

    capsule?.classList.remove('hidden');
    
    if (thumbnailImg) thumbnailImg.src = getImgSrc(currentAudio.thumbnail);
    if (titleEl) titleEl.textContent = currentAudio.title;
    if (categoryEl) categoryEl.textContent = currentAudio.category.split(' ')[0];

    if (expandedTitleEl) expandedTitleEl.textContent = currentAudio.title;
    if (expandedCategoryEl) expandedCategoryEl.textContent = currentAudio.category;

    // Toggle play pause icons
    if (isPlaying) {
      btnPause?.classList.remove('hidden');
      btnPlay?.classList.add('hidden');
    } else {
      btnPause?.classList.add('hidden');
      btnPlay?.classList.remove('hidden');
    }

    // Toggle expanded overlay
    if (isExpanded) {
      expandedOverlay?.classList.remove('hidden');
      if (iframe && !iframe.src) {
        iframe.src = `https://www.youtube.com/embed/${currentAudio.youtubeId}?autoplay=1&controls=1`;
      }
    } else {
      expandedOverlay?.classList.add('hidden');
    }
  };

  const updateColors = (color) => {
    dominantColor = color;
    if (progressBar) progressBar.style.backgroundColor = color;
    if (volumeBar) volumeBar.style.backgroundColor = color;
    if (playToggleBtn) playToggleBtn.style.backgroundColor = color;
    if (gotoDetailsBtn) gotoDetailsBtn.style.backgroundColor = color;
  };

  const playAudio = (audio) => {
    const isNew = !currentAudio || currentAudio.id !== audio.id;
    currentAudio = audio;
    isPlaying = true;

    if (isNew) {
      if (iframe) iframe.src = ''; // Clear old video
      getDominantColor(getImgSrc(audio.thumbnail)).then(color => {
        updateColors(color);
      });
      // Notify details page or navbar of active playing audio change
      window.dispatchEvent(new CustomEvent('audio-changed', { detail: { audio, isPlaying } }));
    } else {
      window.dispatchEvent(new CustomEvent('audio-changed', { detail: { audio, isPlaying } }));
    }

    updateUI();
  };

  const togglePlay = () => {
    isPlaying = !isPlaying;
    
    // In Youtube iframe we can't easily play/pause without API unless we postMessage,
    // but the React app just toggled state. Let's send postMessage to pause/play YouTube iframe!
    if (iframe && iframe.contentWindow) {
      const command = isPlaying ? 'playVideo' : 'pauseVideo';
      iframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: command, args: [] }), '*');
    }

    window.dispatchEvent(new CustomEvent('audio-changed', { detail: { audio: currentAudio, isPlaying } }));
    updateUI();
  };

  // Global listeners
  window.addEventListener('play-audio', (e: CustomEvent) => {
    playAudio(e.detail);
  });

  window.addEventListener('toggle-play', () => {
    togglePlay();
  });

  window.addEventListener('request-player-state', () => {
    // Other pages can ask the player what it is currently doing
    window.dispatchEvent(new CustomEvent('player-state-response', { detail: { currentAudio, isPlaying } }));
  });

  playToggleBtn?.addEventListener('click', togglePlay);
  
  expandBtn?.addEventListener('click', () => {
    isExpanded = true;
    updateUI();
  });

  minimizeBtn?.addEventListener('click', () => {
    isExpanded = false;
    updateUI();
  });

  closeBtn?.addEventListener('click', () => {
    currentAudio = null;
    isPlaying = false;
    isExpanded = false;
    window.dispatchEvent(new CustomEvent('audio-changed', { detail: { audio: null, isPlaying: false } }));
    updateUI();
  });

  const handleGoToDetails = () => {
    if (currentAudio) {
      isExpanded = false;
      updateUI();
      window.location.assign(`/audio/${currentAudio.id}`);
    }
  };

  gotoDetailsBtn?.addEventListener('click', handleGoToDetails);
  thumbnailTrigger?.addEventListener('click', handleGoToDetails);
</script>
