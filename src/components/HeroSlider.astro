---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { getCollection } from 'astro:content';

const currentLocale = Astro.currentLocale || 'en';
const localePrefix = currentLocale === 'en' ? '' : `/${currentLocale}`;

const allSeries = await getCollection('series');

// Configurable featured stories (series slug and 1-based episode number)
const FEATURED_CONFIG = [
  { seriesSlug: 'shaheed-khamenei', episodeNumber: 1 },
  { seriesSlug: 'heavenly-ladies', episodeNumber: 1 },
  { seriesSlug: 'imam-mahdi-under-6', episodeNumber: 1 }
];

const translations = {
  en: {
    listenNow: "Listen Now",
    featuredStory: "Featured Story"
  },
  fr: {
    listenNow: "Écouter Maintenant",
    featuredStory: "Histoire Vedette"
  }
};

const t = translations[currentLocale as 'en' | 'fr'] || translations.en;

// Construct HERO_ITEMS with localized titles and dynamic images
const HERO_ITEMS = FEATURED_CONFIG.map(config => {
  const targetSeries = allSeries.find(s => s.data.slug === config.seriesSlug);
  if (!targetSeries) return null;

  const ep = targetSeries.data.episodes[config.episodeNumber - 1];
  if (!ep) return null;

  const coverUrl = currentLocale === 'en' ? ep.cover.en : (ep.cover.fr || ep.cover.en);
  const epAudioObj = currentLocale === 'en' ? ep.audio.en : (ep.audio.fr || ep.audio.en);
  const title = currentLocale === 'en' ? ep.title.en : (ep.title.fr || ep.title.en);
  const description = currentLocale === 'en' ? ep.description.en : (ep.description.fr || ep.description.en);
  const seriesTitle = currentLocale === 'en' ? targetSeries.data.title.en : (targetSeries.data.title.fr || targetSeries.data.title.en);

  return {
    title: title,
    subtitle: t.featuredStory,
    description: description,
    image: coverUrl,
    audio: {
      id: ep.slug,
      title: title,
      audioUrl: epAudioObj?.url || '',
      thumbnail: coverUrl,
      category: seriesTitle,
      duration: epAudioObj?.duration || '',
      description: description
    }
  };
}).filter(Boolean);
---

{HERO_ITEMS.length > 0 && (
<section 
  id="hero-slider"
  class="relative h-[600px] w-full rounded-[3rem] border-4 border-white dark:border-coffee-800 overflow-hidden flex flex-col md:flex-row items-center transition-all duration-1000 shadow-xl"
  style="background-color: rgba(13, 39, 63, 0.45);"
  data-hero-items={JSON.stringify(HERO_ITEMS)}
  data-locale-prefix={localePrefix}
>
  <!-- Background Image for Mobile Only -->
  <div class="absolute inset-0 z-0 md:hidden flex items-center justify-center">
    <Image id="hero-bg-mobile" src={HERO_ITEMS[0].image as any} class="w-full h-full object-cover" alt="Hero BG Mobile" width={400} height={600} />
    <div class="absolute inset-0 bg-cream-50/90 dark:bg-coffee-900/80 backdrop-blur-[6px]" />
  </div>

  <!-- Decorative Blur Glows (matching dominant color) -->
  <div class="absolute inset-0 pointer-events-none z-0">
    <div 
      id="hero-glow-1"
      class="absolute top-0 left-0 w-[45%] h-[45%] blur-[120px] rounded-full transition-all duration-1000 opacity-30" 
      style="background-color: #0d273f;" 
    />
    <div 
      id="hero-glow-2"
      class="absolute bottom-0 right-0 w-[45%] h-[45%] blur-[120px] rounded-full transition-all duration-1000 opacity-20" 
      style="background-color: #0d273f;" 
    />
  </div>

  <!-- Hero Content -->
  <div class="relative flex-1 p-6 md:p-20 flex flex-col items-center md:items-start text-center md:text-left z-10 space-y-5 md:space-y-8 justify-center h-full">
    <!-- Mobile Feature Image -->
    <div class="md:hidden w-36 h-36 rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white/80 dark:border-coffee-800/80 shrink-0">
       <Image 
        id="hero-image-mobile"
        src={HERO_ITEMS[0].image as any} 
        class="h-full w-full object-cover animate-in fade-in zoom-in duration-500" 
        alt="Featured Thumbnail Mobile"
        width={144}
        height={144}
       />
    </div>

    <div class="space-y-4">
      <span 
        id="hero-subtitle"
        class="inline-block px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest transition-all"
        style="background-color: rgba(13, 39, 63, 0.25); color: #eddcc5;"
      >
        {HERO_ITEMS[0].subtitle}
      </span>
      <h1 id="hero-title" class="text-3xl md:text-7xl font-black text-stone-800 dark:text-stone-100 leading-[1.1] transition-all">
        {HERO_ITEMS[0].title}
      </h1>
      <p id="hero-description" class="text-base md:text-xl text-stone-500 dark:text-stone-400 font-medium max-w-lg mx-auto md:mx-0 leading-relaxed transition-all">
        {HERO_ITEMS[0].description}
      </p>
    </div>
    
    <div class="flex justify-center md:justify-start gap-4">
      <button 
        id="hero-listen-btn"
        class="flex items-center gap-3 px-10 py-5 text-stone-900 font-black rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all text-lg"
        style="background-color: #eddcc5;"
      >
        <Icon name="Play" size={24} fill="currentColor" /> {t.listenNow}
      </button>
    </div>

    <!-- Indicators -->
    <div class="flex items-center justify-center md:justify-start gap-3 pt-6">
      {HERO_ITEMS.map((_, i) => (
        <button 
          class="hero-indicator h-2 transition-all duration-500 rounded-full w-2"
          data-slide-index={i}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  </div>

  <!-- Desktop Feature Image -->
  <div class="relative flex-1 hidden md:flex justify-end h-full p-10 z-10">
     <Image 
      id="hero-image"
      src={HERO_ITEMS[0].image as any} 
      class="h-full w-full object-cover rounded-[3rem] shadow-2xl transition-all duration-700 border-4 border-white/40" 
      alt="Featured Thumbnail"
      width={400}
      height={400}
     />
     
     <div class="absolute bottom-16 right-16 flex gap-4">
        <button id="hero-prev-btn" class="w-12 h-12 bg-white/90 dark:bg-coffee-800/90 backdrop-blur rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all text-stone-800 dark:text-stone-100" aria-label="Previous">
          <Icon name="ChevronLeft" size={24} />
        </button>
        <button id="hero-next-btn" class="w-12 h-12 bg-white/90 dark:bg-coffee-800/90 backdrop-blur rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all text-stone-800 dark:text-stone-100" aria-label="Next">
          <Icon name="ChevronRight" size={24} />
        </button>
     </div>
  </div>
</section>
)}

<script>
  import { getDominantColor } from '../utils/colorExtractor';

  const setupHeroSlider = () => {
    const slider = document.getElementById('hero-slider');
    if (!slider) return;

    const heroItems = JSON.parse(slider.getAttribute('data-hero-items') || '[]');
    const localePrefix = slider.getAttribute('data-locale-prefix') || '';
    if (heroItems.length === 0) return;

    let current = 0;
    let dominantColor = '#eddcc5';
    let timer: any = null;

    const bgMobile = document.getElementById('hero-bg-mobile') as HTMLImageElement;
    const glow1 = document.getElementById('hero-glow-1');
    const glow2 = document.getElementById('hero-glow-2');
    const subtitle = document.getElementById('hero-subtitle');
    const title = document.getElementById('hero-title');
    const description = document.getElementById('hero-description');
    const listenBtn = document.getElementById('hero-listen-btn');
    const heroImage = document.getElementById('hero-image') as HTMLImageElement;
    const heroImageMobile = document.getElementById('hero-image-mobile') as HTMLImageElement;
    
    const indicators = document.querySelectorAll('.hero-indicator');
    const prevBtn = document.getElementById('hero-prev-btn');
    const nextBtn = document.getElementById('hero-next-btn');

    const getImgSrc = (img: any) => typeof img === 'string' ? img : (img?.src || '');

    const updateSlide = () => {
      const item = heroItems[current];
      
      // Update text details
      if (subtitle) subtitle.textContent = item.subtitle;
      if (title) title.textContent = item.title;
      if (description) description.textContent = item.description;
      if (heroImage) heroImage.src = getImgSrc(item.image);
      if (heroImageMobile) heroImageMobile.src = getImgSrc(item.image);
      if (bgMobile) bgMobile.src = getImgSrc(item.image);

      // Reset indicators classes
      indicators.forEach((el, idx) => {
        if (idx === current) {
          el.classList.remove('bg-stone-300', 'dark:bg-stone-700', 'w-2');
          el.classList.add('w-12');
          (el as HTMLElement).style.backgroundColor = dominantColor;
        } else {
          el.classList.add('bg-stone-300', 'dark:bg-stone-700', 'w-2');
          el.classList.remove('w-12');
          (el as HTMLElement).style.backgroundColor = '';
        }
      });

      const getContrastColor = (hex: string) => {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        if (luminance > 0.5) {
          const dr = Math.max(0, Math.round(r * 0.45));
          const dg = Math.max(0, Math.round(g * 0.45));
          const db = Math.max(0, Math.round(b * 0.45));
          return "#" + ((1 << 24) + (dr << 16) + (dg << 8) + db).toString(16).slice(1);
        }
        return hex;
      };

      // Fetch colors and animate
      getDominantColor(getImgSrc(item.image)).then(color => {
        dominantColor = color;
        const contrastColor = getContrastColor(color);
        slider.style.backgroundColor = color + '45';
        if (glow1) glow1.style.backgroundColor = color;
        if (glow2) glow2.style.backgroundColor = color;
        
        if (subtitle) {
          subtitle.style.backgroundColor = color + '25';
          subtitle.style.color = contrastColor;
        }
        if (listenBtn) listenBtn.style.backgroundColor = color;

        // Apply background color to active indicator
        const activeIndicator = document.querySelector(`.hero-indicator[data-slide-index="${current}"]`) as HTMLElement;
        if (activeIndicator) activeIndicator.style.backgroundColor = contrastColor;
      });
    };

    const nextSlide = () => {
      current = (current + 1) % heroItems.length;
      updateSlide();
    };

    const prevSlide = () => {
      current = (current - 1 + heroItems.length) % heroItems.length;
      updateSlide();
    };

    // Setup timer
    const resetTimer = () => {
      if (timer) clearInterval(timer);
      timer = setInterval(nextSlide, 8000);
    };

    prevBtn?.addEventListener('click', () => {
      prevSlide();
      resetTimer();
    });

    nextBtn?.addEventListener('click', () => {
      nextSlide();
      resetTimer();
    });

    indicators.forEach((el, idx) => {
      el.addEventListener('click', () => {
        current = idx;
        updateSlide();
        resetTimer();
      });
    });

    // Listen button click event
    listenBtn?.addEventListener('click', () => {
      const activeAudio = heroItems[current].audio;
      if (activeAudio) {
        window.dispatchEvent(new CustomEvent('play-audio', { detail: activeAudio }));
        window.location.assign(`${localePrefix}/audio/${activeAudio.id}`);
      }
    });

    // Initialize first slide
    updateSlide();
    resetTimer();
  };

  document.addEventListener('astro:page-load', setupHeroSlider);
</script>
