---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import type { AudioContent } from '../types';

interface Props {
  audio: AudioContent;
}

const { audio } = Astro.props;
---

<div 
  class="video-card group relative bg-white dark:bg-slate-800 rounded-[2.5rem] overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border-4 border-white dark:border-slate-700 cursor-pointer flex flex-col transform hover:-translate-y-2"
  data-audio-id={audio.id}
  data-audio-json={JSON.stringify(audio)}
>
  <!-- Thumbnail -->
  <div class="relative aspect-[4/3] overflow-hidden">
    <Image 
      src={audio.thumbnail} 
      alt={audio.title} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors duration-300"></div>
    
    <!-- Play Overlay -->
    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      <div 
        class="w-16 h-16 rounded-full flex items-center justify-center shadow-2xl transform scale-75 group-hover:scale-100 transition-transform duration-500"
        style={`background-color: ${audio.dominantColor}`}
      >
        <Icon name="Play" fill="white" class="text-white ml-1" size={32} />
      </div>
    </div>

    <!-- Badge -->
    <div class="absolute top-4 left-4">
      <span 
        class="flex items-center gap-1 px-3 py-1.5 bg-white/90 dark:bg-slate-800/90 backdrop-blur text-[10px] font-black uppercase tracking-widest rounded-full shadow-sm" 
        style={`color: ${audio.dominantColor}`}
      >
        <Icon name="Sparkles" size={12} /> {audio.category.split(' ')[0]}
      </span>
    </div>
    
    <!-- Duration -->
    <div class="absolute bottom-4 right-4 px-2 py-1 bg-black/50 backdrop-blur text-white text-[10px] font-bold rounded-lg">
      {audio.duration}
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 flex-grow flex flex-col items-center text-center">
    <h3 class="text-xl font-black text-slate-800 dark:text-slate-100 leading-tight mb-2 group-hover:text-sky-600 dark:group-hover:text-sky-400 transition-colors">
      {audio.title}
    </h3>
    {audio.arabicTitle && (
      <span class="font-arabic text-lg text-slate-400 dark:text-slate-500 mb-2">
        {audio.arabicTitle}
      </span>
    )}
    <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2 font-medium mb-4">
      {audio.description}
    </p>
    
    <button 
      class="play-card-btn w-full py-3 rounded-2xl font-black text-sm text-white shadow-lg transition-all transform hover:scale-105 active:scale-95 flex items-center justify-center gap-2"
      style={`background-color: ${audio.dominantColor}`}
    >
      <Icon name="Play" size={16} fill="white" /> LISTEN NOW
    </button>
  </div>
</div>

<script>
  const setupVideoCardListeners = () => {
    const cards = document.querySelectorAll('.video-card');
    cards.forEach(card => {
      const audioId = card.getAttribute('data-audio-id');
      const audioJson = card.getAttribute('data-audio-json');
      const playBtn = card.querySelector('.play-card-btn');

      if (!audioId || !audioJson) return;
      const audio = JSON.parse(audioJson);

      // Card navigation click handler
      card.addEventListener('click', (e) => {
        // If play button clicked, don't navigate
        if (playBtn && playBtn.contains(e.target as Node)) {
          return;
        }
        window.location.assign(`/audio/${audioId}`);
      });

      // Play button handler
      playBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        window.dispatchEvent(new CustomEvent('play-audio', { detail: audio }));
      });
    });
  };

  document.addEventListener('astro:page-load', setupVideoCardListeners);
</script>
