---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/Navbar.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  alternateUrl?: string;
}

const { title = 'Bab Al-Ridha Kids', alternateUrl } = Astro.props;
const currentLocale = Astro.currentLocale || 'en';
---

<!DOCTYPE html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&family=Amiri:wght@400;700&display=swap" rel="stylesheet" />
    
    <!-- Theme blocking script to prevent flash-of-light-mode & handle language redirect on root -->
    <script is:inline>
      const getTheme = () => {
        const saved = localStorage.getItem('app-theme');
        if (saved) return saved;
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      };
      if (getTheme() === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      // Auto-redirect to preference on root index page
      if (window.location.pathname === '/' && localStorage.getItem('language') === 'fr') {
        window.location.replace('/fr');
      }
    </script>
    
    <ClientRouter />
  </head>
  <body class="transition-colors duration-500 min-h-screen flex flex-col islamic-pattern bg-cream-50 dark:bg-coffee-900">
    <Navbar alternateUrl={alternateUrl} />
    <main class="flex-grow pb-40 pt-24 md:pt-32">
      <slot />
    </main>
    <AudioPlayer />

    <script>
      // Scroll reveal logic
      const initReveal = () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            }
          });
        }, { threshold: 0.1 });

        const elements = document.querySelectorAll('.reveal');
        elements.forEach(el => observer.observe(el));
      };

      const updateTheme = () => {
        const saved = localStorage.getItem('app-theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (saved === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      document.addEventListener('astro:after-swap', updateTheme);
      document.addEventListener('astro:page-load', () => {
        updateTheme();
        initReveal();
      });
    </script>
  </body>
</html>
