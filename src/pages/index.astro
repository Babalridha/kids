---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import HeroSlider from '../components/HeroSlider.astro';
import Icon from '../components/Icon.astro';
import { CATEGORIES, AUDIOS } from '../data/mockData';
---

<Layout title="Bab Al-Ridha Kids">
  <div class="max-w-7xl mx-auto px-6 space-y-24 pb-40 pt-4 md:pt-8">
    <div class="reveal">
      <HeroSlider />
    </div>

    <!-- Top Series Thumbnail Grid -->
    <section class="space-y-10 reveal">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
           <div class="w-10 h-10 bg-accent-light/30 dark:bg-accent-dark/10 rounded-2xl flex items-center justify-center text-xl shadow-sm">
              <span class="text-amber-500"><Icon name="Sparkles" size={20} /></span>
           </div>
           <h2 class="text-3xl font-black text-stone-800 dark:text-stone-100">Top Series</h2>
        </div>
        <a href="/categories" class="group flex items-center gap-2 text-stone-500 font-bold hover:text-stone-800 dark:hover:text-white transition-all">
          See all series 
          <span class="group-hover:translate-x-1 transition-transform"><Icon name="ChevronRight" size={18} /></span>
        </a>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
         {CATEGORIES.slice(0, 5).map(cat => (
           <a 
            href={`/category/${cat.name}`}
            class="group relative aspect-[3/4] rounded-[2.5rem] overflow-hidden border-4 border-white dark:border-coffee-800 shadow-xl hover:scale-105 transition-all duration-500"
           >
             <Image src={cat.image} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={cat.name} width={400} height={500} />
             <div class="absolute inset-0 bg-gradient-to-t from-stone-900/90 via-transparent to-transparent" />
             <div class="absolute bottom-6 left-6 right-6">
                <h3 class="text-white font-black text-lg leading-tight">{cat.name.split(' ')[0]}</h3>
                <p class="text-stone-300 text-[10px] font-bold uppercase tracking-widest">{cat.episodes} episodes</p>
             </div>
           </a>
         ))}
      </div>
    </section>

    <!-- Fresh Stories Grid -->
    <section class="space-y-10 reveal">
      <div class="flex flex-col gap-2">
         <h2 class="text-3xl font-black text-stone-800 dark:text-stone-100">Fresh Stories</h2>
         <p class="text-stone-500 dark:text-stone-400 font-medium">New additions to keep your hearts growing and minds glowing.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
         {AUDIOS.map(audio => (
           <a href={`/audio/${audio.id}`} class="group flex flex-col items-center text-center space-y-6">
              <div class="relative aspect-square w-full rounded-[3.5rem] overflow-hidden shadow-xl group-hover:shadow-[0_40px_80px_-15px_rgba(0,0,0,0.2)] transition-all duration-700 transform group-hover:-translate-y-3 border-8 border-white dark:border-stone-900">
                 <Image src={audio.thumbnail} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={audio.title} width={400} height={400} />
                 <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <div class="w-16 h-16 bg-white/30 backdrop-blur rounded-full flex items-center justify-center text-white scale-75 group-hover:scale-100 transition-transform duration-500">
                       <Icon name="Play" fill="currentColor" size={32} />
                    </div>
                 </div>
              </div>
              <div class="space-y-2 max-w-[200px]">
                 <h3 class="text-xl font-black text-stone-800 dark:text-stone-100 leading-tight group-hover:text-stone-900 dark:group-hover:text-accent-dark transition-colors">{audio.title}</h3>
                 <div class="flex items-center justify-center gap-3 text-stone-400 dark:text-stone-500 font-black text-[10px] uppercase tracking-[0.2em]">
                    <span>{audio.category.split(' ')[0]}</span>
                    <span class="w-1.5 h-1.5 bg-stone-200 dark:bg-stone-800 rounded-full" />
                    <span>{audio.duration}</span>
                 </div>
              </div>
           </a>
         ))}
      </div>
    </section>

    <!-- Family Join Banner -->
    <section class="relative overflow-hidden bg-cream-100 dark:bg-coffee-800 rounded-[4rem] p-12 md:p-24 text-center space-y-10 border-4 border-white dark:border-coffee-900 shadow-lg reveal">
      <div class="absolute -top-10 -left-10 w-40 h-40 bg-accent-light blur-3xl rounded-full opacity-30" />
      <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-pink-200 blur-3xl rounded-full opacity-30" />
      
      <div class="relative z-10 space-y-6">
        <h2 class="text-4xl md:text-6xl font-black text-stone-800 dark:text-stone-100">Never Miss a Story</h2>
        <p class="text-xl text-stone-500 dark:text-stone-400 font-medium max-w-2xl mx-auto leading-relaxed">
          Join thousands of families in our beautiful journey. Subscribe to get notifications about new series and special resources for parents.
        </p>
      </div>
      <div class="relative z-10 flex flex-col sm:flex-row gap-4 justify-center items-center max-w-xl mx-auto pt-4">
        <input 
          type="email" 
          placeholder="Your email address" 
          class="w-full px-10 py-6 rounded-full bg-white dark:bg-stone-900 border-none outline-none shadow-sm text-stone-700 dark:text-stone-100 font-bold text-lg ring-4 ring-accent-light/50 dark:ring-accent-dark/5" 
        />
        <button class="w-full sm:w-auto px-12 py-6 bg-accent-light dark:bg-accent-dark text-stone-900 font-black rounded-full shadow-2xl hover:scale-105 active:scale-95 transition-all text-lg uppercase">
          Subscribe
        </button>
      </div>
    </section>
  </div>
</Layout>
