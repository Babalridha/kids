---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { CATEGORIES } from '../data/mockData';
---

<Layout title="Discover Series - Bab Al-Ridha Kids">
  <div class="max-w-7xl mx-auto px-6 space-y-16 py-16 pb-48">
    <div class="text-center space-y-4 max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-7xl font-black text-stone-800 dark:text-stone-100 tracking-tight">Discover our Collections</h1>
      <p class="text-xl text-stone-500 dark:text-stone-400 font-medium leading-relaxed">
        Explore all of our carefully crafted series, designed to inspire, educate, and delight the young lovers of Ahlulbayt (as).
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {CATEGORIES.map(cat => (
        <a 
          href={`/category/${cat.name}`}
          class="group relative h-[450px] rounded-[4rem] overflow-hidden border-8 border-white dark:border-stone-900 shadow-2xl hover:scale-[1.03] transition-all duration-500"
        >
          <Image src={cat.image} class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" alt={cat.name} />
          <div class="absolute inset-0 bg-gradient-to-t from-stone-950/90 via-stone-950/20 to-transparent" />
          
          <div class="absolute top-8 left-8">
             <div class="flex items-center gap-2 px-4 py-2 bg-white/20 backdrop-blur-md rounded-2xl border border-white/30 text-white text-[10px] font-black uppercase tracking-widest shadow-lg">
               <Icon name="Sparkles" size={12} /> {cat.episodes} Episodes
             </div>
          </div>

          <div class="absolute bottom-10 left-10 right-10 text-white space-y-4">
             <h3 class="text-3xl font-black leading-tight drop-shadow-md">{cat.name}</h3>
             <p class="text-sm font-medium text-stone-200 opacity-0 group-hover:opacity-100 transition-all duration-500 line-clamp-2 transform translate-y-2 group-hover:translate-y-0">
               {cat.description}
             </p>
             <div class="flex items-center gap-2 text-accent-dark font-black text-xs pt-2">
               <Icon name="PlayCircle" size={20} /> START JOURNEY
             </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
