---
import { Image } from 'astro:assets';
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allSeries = await getCollection('series');
  const paths = [];

  for (const s of allSeries) {
    if (s.data.locales.includes('en')) {
      const nameEn = s.data.name_en;
      const nameFr = s.data.name_fr || s.data.name_en;
      paths.push({
        params: {
          locale: undefined,
          name: nameEn
        },
        props: { 
          series: s, 
          locale: 'en',
          alternateUrl: s.data.locales.includes('fr') ? `/fr/category/${encodeURIComponent(nameFr)}` : undefined
        }
      });
    }
    if (s.data.locales.includes('fr')) {
      const nameEn = s.data.name_en;
      const nameFr = s.data.name_fr || s.data.name_en;
      paths.push({
        params: {
          locale: 'fr',
          name: nameFr
        },
        props: { 
          series: s, 
          locale: 'fr',
          alternateUrl: s.data.locales.includes('en') ? `/category/${encodeURIComponent(nameEn)}` : undefined
        }
      });
    }
  }
  return paths;
}

const { series, locale, alternateUrl } = Astro.props;

const currentLocale = locale || 'en';
const localePrefix = currentLocale === 'en' ? '' : `/${currentLocale}`;

const categoryName = currentLocale === 'en' ? series.data.name_en : (series.data.name_fr || series.data.name_en);
const categoryDesc = currentLocale === 'en' ? series.data.description_en : (series.data.description_fr || series.data.description_en);
const categoryImage = currentLocale === 'en' ? series.data.image_en : (series.data.image_fr || series.data.image_en);
const dominantColor = series.data.color || '#0d273f';

const filteredAudios = series.data.episodes.map(ep => {
  const epThumbnail = currentLocale === 'en' ? ep.thumbnail_en : (ep.thumbnail_fr || ep.thumbnail_en);
  return {
    id: ep.id,
    title: currentLocale === 'en' ? ep.title_en : (ep.title_fr || ep.title_en),
    audioUrl: ep.audioUrl,
    thumbnail: epThumbnail,
    category: categoryName,
    duration: ep.duration,
    description: currentLocale === 'en' ? ep.description_en : (ep.description_fr || ep.description_en)
  };
});

function getContrastColor(hex: string) {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
  if (luminance > 0.5) {
    const dr = Math.max(0, Math.round(r * 0.45));
    const dg = Math.max(0, Math.round(g * 0.45));
    const db = Math.max(0, Math.round(b * 0.45));
    return "#" + ((1 << 24) + (dr << 16) + (dg << 8) + db).toString(16).slice(1);
  }
  return hex;
}

const translations = {
  en: {
    breadcrumbs: ["Home", "Series"],
    collectionSeries: "Collection Series",
    startSeries: "START SERIES",
    saveSeries: "SAVE SERIES",
    saved: "SAVED",
    episodes: "Episodes",
    totalTime: "Total time: 1h 45m"
  },
  fr: {
    breadcrumbs: ["Accueil", "Séries"],
    collectionSeries: "Série de Collection",
    startSeries: "LANCER LA SÉRIE",
    saveSeries: "ENREGISTRER LA SÉRIE",
    saved: "ENREGISTRÉ",
    episodes: "Épisodes",
    totalTime: "Temps total : 1h 45m"
  }
};
const t = translations[currentLocale as 'en' | 'fr'] || translations.en;
---

<Layout title={`${categoryName} - Bab Al-Ridha Kids`} alternateUrl={alternateUrl}>
  <div 
    id="category-page-container"
    class="min-h-screen py-10 pb-40"
    data-category-name={series.data.name_en}
    data-locale-prefix={localePrefix}
  >
    <div class="max-w-7xl mx-auto px-6 space-y-16">
      
      <!-- Navigation Breadcrumbs -->
      <div class="flex items-center gap-2 text-sm text-stone-400 font-bold uppercase tracking-widest">
        <a href={localePrefix || '/'} class="hover:text-stone-800 dark:hover:text-white transition-colors">{t.breadcrumbs[0]}</a>
        <span>›</span>
        <a href={`${localePrefix}/categories`} class="hover:text-stone-800 dark:hover:text-white transition-colors">{t.breadcrumbs[1]}</a>
        <span>›</span>
        <span class="text-stone-800 dark:text-white">{categoryName}</span>
      </div>

      <!-- Hero Series Header background adapts to dominant color -->
      <div 
        id="category-header-banner"
        style={`background-color: ${dominantColor}45`}
        class="rounded-[4rem] p-10 md:p-16 border-4 border-white dark:border-coffee-800 flex flex-col md:flex-row items-center gap-12 shadow-xl"
      >
        <div class="relative shrink-0">
           <div class="w-48 h-48 md:w-72 md:h-72 rounded-[3.5rem] overflow-hidden shadow-2xl bg-white dark:bg-coffee-900 p-3 border-4 border-cream-50 dark:border-coffee-700">
              <Image id="category-hero-image" src={categoryImage as any} width={288} height={288} class="w-full h-full object-cover rounded-[2.5rem]" alt={categoryName} />
           </div>
         </div>
         <div class="space-y-8 flex-grow">
           <span 
             id="category-badge"
             class="px-5 py-2 rounded-full text-xs font-black uppercase tracking-widest"
             style={`background-color: ${dominantColor}20; color: ${getContrastColor(dominantColor)}`}
           >
             {t.collectionSeries}
           </span>
           <h1 class="text-4xl md:text-7xl font-black text-stone-800 dark:text-stone-100 leading-[1.1] tracking-tight">{categoryName}</h1>
           <p class="text-xl text-stone-500 dark:text-stone-400 font-medium max-w-3xl leading-relaxed">
            {categoryDesc} Narration specifically tailored for little hearts to learn and grow in the light of the Ahlulbayt (as).
          </p>
          <div class="flex flex-wrap gap-4">
            <button 
              id="start-series-btn"
              data-first-audio-json={filteredAudios.length > 0 ? JSON.stringify(filteredAudios[0]) : null}
              class="flex items-center gap-3 px-12 py-6 text-stone-900 font-black rounded-full shadow-2xl hover:scale-105 transition-transform duration-300 text-xl"
              style={`background-color: ${dominantColor}`}
            >
              <Icon name="Play" size={24} fill="currentColor" /> {t.startSeries}
            </button>
            <button 
              id="save-series-btn"
              class="flex items-center gap-3 px-12 py-6 bg-white dark:bg-coffee-900 text-stone-700 dark:text-stone-100 font-black rounded-full border-4 transition-all text-xl border-cream-200 dark:border-coffee-700 hover:bg-cream-50 dark:hover:bg-coffee-800"
            >
              <!-- Filled and empty hearts toggled via class -->
              <span id="heart-empty"><Icon name="Heart" size={24} /></span>
              <span id="heart-filled" class="hidden text-pink-500"><Icon name="Heart" size={24} fill="currentColor" /></span>
              <span id="save-series-text" data-text-saved={t.saved} data-text-save={t.saveSeries}>{t.saveSeries}</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Stats Header -->
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-cream-200 dark:border-coffee-800 pb-8">
         <div class="flex items-center gap-8 text-stone-400 font-black uppercase tracking-widest text-sm">
            <span>{filteredAudios.length} {t.episodes}</span>
            <span class="flex items-center gap-2"><Icon name="Clock" size={18} /> {t.totalTime}</span>
         </div>
      </div>

      <!-- Episodes Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
         {filteredAudios.map((audio, idx) => (
           <div 
            class="episode-card group flex flex-col space-y-6 cursor-pointer"
            data-audio-json={JSON.stringify(audio)}
            data-audio-id={audio.id}
            style={`--hover-color: ${getContrastColor(dominantColor)};`}
           >
              <div class="relative aspect-square rounded-[3.5rem] overflow-hidden shadow-xl group-hover:shadow-2xl transition-all duration-500 border-8 border-white dark:border-coffee-800">
                 <Image src={audio.thumbnail as any} width={400} height={400} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt={audio.title} />
                 <div class="absolute inset-0 bg-stone-900/10 group-hover:bg-stone-900/0 transition-all" />
                 <div class="absolute bottom-6 left-6 bg-white/20 backdrop-blur-md px-4 py-2 rounded-xl text-[10px] font-black text-white uppercase tracking-widest border border-white/30">
                   EP 0{idx + 1}
                 </div>
                 <div class="absolute top-6 right-6 w-12 h-12 bg-white/30 backdrop-blur-md rounded-2xl flex items-center justify-center text-white scale-0 group-hover:scale-100 transition-transform duration-300">
                    <Icon name="Play" fill="currentColor" size={24} />
                 </div>
              </div>
              <div class="text-center space-y-2">
                 <h3 class="text-xl font-black text-stone-800 dark:text-stone-100 leading-tight truncate group-hover:text-[var(--hover-color)] transition-colors">{audio.title}</h3>
                 <p class="text-xs text-stone-400 font-black uppercase tracking-widest">{audio.duration}</p>
              </div>
           </div>
         ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  import { getDominantColor } from '../../../utils/colorExtractor';

  const setupCategoryPage = () => {
    const container = document.getElementById('category-page-container');
    if (!container) return;
    const name = container.getAttribute('data-category-name');
    const localePrefix = container.getAttribute('data-locale-prefix') || '';

    const saveBtn = document.getElementById('save-series-btn');
    const heartEmpty = document.getElementById('heart-empty');
    const heartFilled = document.getElementById('heart-filled');
    const saveText = document.getElementById('save-series-text');
    const startBtn = document.getElementById('start-series-btn');

    // Extract dominant color of the hero image dynamically
    const heroImage = document.getElementById('category-hero-image') as HTMLImageElement;
    const headerBanner = document.getElementById('category-header-banner');
    const badge = document.getElementById('category-badge');

    if (heroImage && headerBanner) {
      const getImgSrc = (img: HTMLImageElement) => img.src || '';
      
      const getContrastColor = (hex: string) => {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
        if (luminance > 0.5) {
          const dr = Math.max(0, Math.round(r * 0.45));
          const dg = Math.max(0, Math.round(g * 0.45));
          const db = Math.max(0, Math.round(b * 0.45));
          return "#" + ((1 << 24) + (dr << 16) + (dg << 8) + db).toString(16).slice(1);
        }
        return hex;
      };

      getDominantColor(getImgSrc(heroImage)).then(color => {
        const contrastColor = getContrastColor(color);
        headerBanner.style.backgroundColor = color + '45';
        if (badge) {
          badge.style.backgroundColor = color + '20';
          badge.style.color = contrastColor;
        }
        if (startBtn) {
          startBtn.style.backgroundColor = color;
        }
        
        // Update hovered color variable dynamically
        const episodeCards = document.querySelectorAll('.episode-card');
        episodeCards.forEach(card => {
          (card as HTMLElement).style.setProperty('--hover-color', contrastColor);
        });
      });
    }

    if (!saveBtn) return;

    const checkSaved = () => {
      let saved = [];
      try {
        saved = JSON.parse(localStorage.getItem('saved-series') || '[]');
      } catch (e) {}

      const isSaved = saved.includes(name);
      if (isSaved) {
        saveBtn.classList.remove('text-stone-700', 'dark:text-stone-100', 'border-cream-200', 'dark:border-coffee-700');
        saveBtn.classList.add('text-pink-500', 'border-pink-200');
        heartEmpty?.classList.add('hidden');
        heartFilled?.classList.remove('hidden');
        if (saveText) saveText.textContent = saveText.getAttribute('data-text-saved') || 'SAVED';
      } else {
        saveBtn.classList.add('text-stone-700', 'dark:text-stone-100', 'border-cream-200', 'dark:border-coffee-700');
        saveBtn.classList.remove('text-pink-500', 'border-pink-200');
        heartEmpty?.classList.remove('hidden');
        heartFilled?.classList.add('hidden');
        if (saveText) saveText.textContent = saveText.getAttribute('data-text-save') || 'SAVE SERIES';
      }
    };

    saveBtn.addEventListener('click', () => {
      let saved = [];
      try {
        saved = JSON.parse(localStorage.getItem('saved-series') || '[]');
      } catch (e) {}

      if (saved.includes(name)) {
        saved = saved.filter((x: any) => x !== name);
      } else {
        saved.push(name);
      }
      localStorage.setItem('saved-series', JSON.stringify(saved));
      checkSaved();
    });

    checkSaved(); // Run once on page load

    // Start Series Button Click
    startBtn?.addEventListener('click', () => {
      const audioJson = startBtn.getAttribute('data-first-audio-json');
      if (audioJson) {
        const audio = JSON.parse(audioJson);
        window.dispatchEvent(new CustomEvent('play-audio', { detail: audio }));
        window.location.assign(`${localePrefix}/audio/${audio.id}`);
      }
    });

    // Episode Cards click
    const episodeCards = document.querySelectorAll('.episode-card');
    episodeCards.forEach(card => {
      card.addEventListener('click', () => {
        const audioJson = card.getAttribute('data-audio-json');
        const audioId = card.getAttribute('data-audio-id');
        if (audioJson && audioId) {
          const audio = JSON.parse(audioJson);
          window.dispatchEvent(new CustomEvent('play-audio', { detail: audio }));
          window.location.assign(`${localePrefix}/audio/${audioId}`);
        }
      });
    });
  };

  document.addEventListener('astro:page-load', setupCategoryPage);
</script>
